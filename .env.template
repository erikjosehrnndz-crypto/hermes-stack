# =========================================================================
# HERMES STACK — TEMPLATE DE VARIABLES DE ENTORNO
# =========================================================================
# Copia este archivo como '.env' y rellena cada valor:
#   cp .env.template .env && nano .env
# NUNCA subas el .env real al repositorio (está en .gitignore).
# Los valores reales viajan cifrados en el bundle de estado (Tier 2).

# ── Router LiteLLM y seguridad ──
# Invéntala tú (cualquier cadena tipo sk-litellm-...). La usan hermes y brain.
LITELLM_MASTER_KEY=sk-litellm-CAMBIA-ESTO

# ── Proveedores LLM (los usa LiteLLM) ──
OPENROUTER_API_KEY=sk-or-v1-CAMBIA-ESTO
GEMINI_API_KEY=CAMBIA-ESTO

# ── ElevenLabs (síntesis de voz) ──
ELEVENLABS_API_KEY=CAMBIA-ESTO
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel por defecto; cámbiala si clonas tu voz
# Modelo del agente (default: gemini-flash)
HERMES_MODEL=gemini-flash

# ── Brain (segundo cerebro / RAG) ──
# Invéntalo tú (token para autenticar a hermes contra brain).
BRAIN_API_TOKEN=CAMBIA-ESTO

# ── 9router (router multi-proveedor) ──
ROUTER_JWT_SECRET=CAMBIA-ESTO            # cadena larga aleatoria
ROUTER_INITIAL_PASSWORD=CAMBIA-ESTO      # contraseña inicial del panel

# ── Servicios de datos ──
COUCHDB_PASSWORD=CAMBIA-ESTO             # solo si usas Obsidian LiveSync (opcional)
FILEBROWSER_PASSWORD=CAMBIA-ESTO

# ── Despliegue / infra (opcionales) ──
DIGITALOCEAN_TOKEN=CAMBIA-ESTO           # backups remotos a la droplet DO
RUNPOD_API_KEY=CAMBIA-ESTO               # GPU bajo demanda (si aplica)
SYNCTHING_PASSWORD=CAMBIA-ESTO           # solo si usas Syncthing (opcional)
